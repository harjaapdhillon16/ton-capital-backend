# TON / Storm
TONCENTER_RPC_URL=https://toncenter.com/api/v2/jsonRPC
TONCENTER_API_KEY=
STORM_API_URL=https://api5.storm.tg/api
ORACLE_URL=https://oracle.storm.tg
STORM_NETWORK=mainnet
USDT_JETTON_MASTER=EQCxE6mUtQJKFnGfaROTKOt1lZbDiiX1kCixRv7Nw2Id_sDs
# deposit settlement:
# - ston_auto: automatic TON->USDT via STON.fi + transfer to trade wallet (default)
# - swap_webhook: call your own TON->USDT conversion service
# - treasury_usdt: direct USDT payout from treasury wallet
DEPOSIT_SETTLEMENT_MODE=ston_auto
TON_USDT_SWAP_WEBHOOK_URL=
TON_USDT_SWAP_WEBHOOK_TOKEN=
AGENT_WALLET_ADDRESS=
AGENT_WALLET_MNEMONIC=
USER_TRADE_WALLET_VERSION=v4

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# External data
